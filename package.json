{
  "name": "init",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:init": "pnpm dlx prisma init --output ../app/generated/prisma",
    "db:migrate": "pnpm dlx prisma migrate dev",
    "db:push": "pnpm dlx prisma db push",
    "db:generate": "pnpm dlx prisma generate",
    "db:seed": "pnpm dlx prisma db seed",
    "db:studio": "pnpm dlx prisma studio --browser none",
    "db:reset": "pnpm dlx prisma migrate reset",
    "db:dev": "pnpm db:push && pnpm db:generate",
    "auth:gen": "pnpm dlx auth@latest generate --config \"./app/.server/auth.server.ts\" --output \"./app/.server\" --yes",
    "email:dev": "email dev --dir ./app/emails"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/prisma-adapter": "^1.6.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@liorpo/react-hook-form-persist": "^1.0.10",
    "@neondatabase/serverless": "^1.1.0",
    "@opencoredev/email-sdk": "^0.6.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@shadcn/react": "^0.2.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/react-router": "^1.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@xstate/store": "^4.2.1",
    "@xstate/store-react": "^2.0.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
